# ─── docvault-rag environment variables ───────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8000

# ── Internal auth (must match INTERNAL_RAG_KEY in docvault-api) ────────────────
INTERNAL_RAG_KEY=change_me_shared_secret

# ── Storage ────────────────────────────────────────────────────────────────────
# Relative to the repo root (resolved to absolute at startup)
FILE_STORAGE_PATH=../shared-storage

# Local Chroma persistent store (relative to docvault-rag/ directory)
CHROMA_PATH=./chroma

# ── Gemini / Embeddings ────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Embeddings backend: huggingface or gemini
EMBEDDINGS_PROVIDER=huggingface

# Used when EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_MODEL=models/embedding-001

# Used when EMBEDDINGS_PROVIDER=huggingface
HF_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Gemini non-streaming chat model used by /rag/chat
GEMINI_CHAT_MODEL=models/gemini-1.5-flash

# Chunk batching: how many chunks to embed per Gemini API call (default 25)
EMBED_BATCH_SIZE=25

# Milliseconds to wait between embedding batches (default 200)
EMBED_BATCH_DELAY_MS=200

# Number of chunks to retrieve for chat context
RETRIEVAL_TOP_K=5

# ── PDF processing ─────────────────────────────────────────────────────────────
# Pages with fewer characters than this are skipped (blank/image-only pages)
MIN_PAGE_CHARS=50

# ── Express API (webhook target) ───────────────────────────────────────────────
API_SERVICE_URL=http://localhost:4000
