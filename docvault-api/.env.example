# ─── docvault-api environment variables ───────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/docvault

# JWT / Auth
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
COOKIE_NAME=docvault_token

# CORS — set to wherever your frontend runs
FRONTEND_ORIGIN=http://localhost:3001

# Internal communication
RAG_SERVICE_URL=http://localhost:8000
INTERNAL_RAG_KEY=REPLACE_WITH_SHARED_SECRET
RAG_CHAT_TIMEOUT_MS=20000

# Shared file storage (relative to repo root)
FILE_STORAGE_PATH=../shared-storage
# Maximum upload size in megabytes (default: 25)
MAX_UPLOAD_MB=25
